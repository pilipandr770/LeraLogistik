# ============================================
# Environment variables for Lera Logistics
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# --- Application ---
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
# Local Docker:   postgresql+asyncpg://lera:lera@localhost:5432/lera
# Render.com DB:  postgresql+asyncpg://ittoken_db_user:PASSWORD@dpg-xxx.frankfurt-postgres.render.com/ittoken_db
#
# To use the Render DB locally, paste the Render EXTERNAL URL here.
# (Get it from Render dashboard → your DB → "External Database URL")
DATABASE_URL=postgresql+asyncpg://lera:lera@localhost:5432/lera

# PostgreSQL schema — isolates this project from others in the same shared DB.
# Never change this after first migration, or you'll lose your data.
DB_SCHEMA=lera_logistics

# --- Lardi-Trans API ---
# Get this token at https://lardi-trans.com/log/settings/api/
# The token must be activated by Lardi-Trans support.
LARDI_API_TOKEN=your-lardi-token-here
LARDI_API_BASE_URL=https://api.lardi-trans.com/v2
LARDI_API_LANGUAGE=uk            # uk | ru | en
LARDI_POLL_INTERVAL_SECONDS=60   # how often to fetch new proposals

# --- Anthropic Claude API ---
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
# For lighter/cheaper tasks:
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# --- Feature flags (MVP safety switches) ---
# Turn these on ONLY when you're ready. Start with everything OFF = human-in-the-loop.
AGENT_MATCHER_ENABLED=true        # safe: only suggests matches, no external actions
AGENT_PRICING_ENABLED=true        # safe: only suggests prices
AGENT_NEGOTIATOR_AUTO_SEND=false  # DANGER: when true, agent sends messages by itself
AGENT_AUTO_ACCEPT_DEALS=false     # DANGER: when true, agent closes deals autonomously

# --- Authentication (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-different-from-APP_SECRET_KEY
JWT_EXPIRE_MINUTES=43200          # 30 days

# --- Verification APIs ---
# OpenDataBot — Ukrainian company registry lookups (ЄДРПОУ)
# Free tier at https://opendatabot.ua/ — register and get your API key
# Without this key registrations still work, but verification is marked "manual required"
OPENDATABOT_API_KEY=

# EU VIES validation uses the official free EU Commission API — no key needed
# https://ec.europa.eu/taxation_customs/vies/

# --- Traccar GPS telematics (self-hosted, recommended) ---
# Traccar is open-source (Apache 2.0): https://www.traccar.org/
# Default values below match the docker-compose.yml setup.
# Change these if you're running Traccar on a different server or port.
#
# How to start locally:
#   docker compose up traccar
# Admin UI: http://localhost:8082 (login with email + password you set below)
#
# TRACCAR_ADMIN_PASSWORD must be set for GPS polling to activate.
# Leave blank to disable GPS tracking entirely.
TRACCAR_BASE_URL=http://localhost:8082
TRACCAR_ADMIN_EMAIL=admin@trucklink.ua
TRACCAR_ADMIN_PASSWORD=
TRACCAR_POLL_INTERVAL_SECONDS=30

# --- Navixy GPS telematics (SaaS fallback — for carriers already on Navixy) ---
# Sign up at https://navixy.com — not needed if using self-hosted Traccar above.
# API docs: https://developers.navixy.com/api-reference/
NAVIXY_API_BASE=https://api.eu.navixy.com/v2
